__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env
.idea/
.vscode/
.DS_Store

# pip build metadata (re-generated by `pip install -e .` on every node)
*.egg-info/
build/
dist/

# Heavy checkpoint blobs (ignored so `git add .` stays safe). Full trees are
# published intentionally via:  python scripts/push_artifacts.py  (uses git add -f).
data/raw/
results/rank_*/checkpoints/*/pytorch_model.bin
results/rank_*/checkpoints/*/model.safetensors
results/rank_*/checkpoints/*/optimizer.pt
results/rank_*/checkpoints/*/scheduler.pt
results/rank_*/checkpoints/*/rng_state.pth
*.onnx

# Allow LoRA adapters and metric/profile artifacts
!results/rank_*/checkpoints/*/adapter_model.safetensors
!results/rank_*/checkpoints/*/adapter_config.json
!results/rank_*/metrics/
!results/rank_*/profile/
!results/rank_*/plots/
